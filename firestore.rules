// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: scans
// Document ID: auto-generated
// Fields:
//   - userId: string (required) - The UID of the user who performed the scan.
//   - type: string (required, enum: ["email", "sms", "url"]) - The type of content scanned.
//   - content: string (required) - The content that was scanned (text or URL).
//   - riskScore: integer (required, 0-100) - The risk score.
//   - riskLevel: string (required, enum: ["Low", "Medium", "High"]) - The risk level.
//   - reasons: list (optional, list of strings) - List of reasons why the content was flagged.
//   - explanation: string (optional) - Detailed AI explanation of the risk.
//   - timestamp: timestamp (required) - When the scan was performed.
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isValidScan(data) {
      return data.keys().hasAll(['userId', 'type', 'content', 'riskScore', 'riskLevel', 'timestamp']) &&
             data.userId is string &&
             data.type in ['email', 'sms', 'url'] &&
             data.content is string && data.content.size() < 10000 &&
             data.riskScore is int && data.riskScore >= 0 && data.riskScore <= 100 &&
             data.riskLevel in ['Low', 'Medium', 'High'] &&
             data.timestamp is timestamp;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /scans/{scanId} {
      // Users can only read their own scans
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      
      // Users can only create scans for themselves
      allow create: if isAuthenticated() && 
                    request.resource.data.userId == request.auth.uid &&
                    isValidScan(request.resource.data);
      
      // Scans are immutable once created
      allow update, delete: if false;
    }
  }
}
